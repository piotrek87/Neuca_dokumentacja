    bindCrmValuesToForm: function (iframe, fields, crmData) {
        var childCtrl = Xrm.Page.ui.controls.get(iframe).getObject().contentWindow.document;

        for (var i = 0; i < fields.length; i++) {
            var valueToSet = '';
            var currFieldName = fields[i];
            var currVal = crmData[currFieldName];
            var typeOf = typeof (currVal);
            if (currVal === null) {
                valueToSet = '';
            } else if (typeOf === 'object') {
                valueToSet = currVal.Name;
            } else if (typeOf === 'boolean') {
                if (currVal)
                    valueToSet = 'Yes';
                else
                    valueToSet = 'No';
            } else {
                valueToSet = currVal;
            }
            if (valueToSet == null) {
                valueToSet = '';
            }
            var ctrlToSetValue = childCtrl.getElementById(currFieldName);
            if (ctrlToSetValue != null) {
                ctrlToSetValue.value = valueToSet;
            }
        }
    },
