            contentType: "application/json; charset=utf-8",
            datatype: "json",
            url: odataSelect,
            beforeSend: function (XMLHttpRequest) { XMLHttpRequest.setRequestHeader("Accept", "application/json"); },
            success: function (data, textStatus, XmlHttpRequest) {
                var myCurrency = data.d.results[0];
                var idValue = eval('myCurrency.TransactionCurrencyId');
                var textValue = eval('myCurrency.CurrencyName');
                var thisEntityType = 'transactioncurrency';
                Xrm.Page.getAttribute("transactioncurrencyid").setValue([{ id: idValue, name: textValue, entityType: thisEntityType }]);
            },
            error: function (XmlHttpRequest, textStatus, errorThrown) { alert('OData Select Failed: ' + odataSelect); }
        });
    },

    setRestValue: function (attributeName, restValue) {
        var uiUtils = Neuca.Crm.UiUtils
            , __metadata = null
            , isLookup = false
            , isOptionSet = false
            , isMoney = false;

        var attribute = uiUtils.getField(attributeName);

        if (restValue && restValue.__metadata) {
            __metadata = restValue.__metadata;

            isLookup = __metadata.type === 'Microsoft.Crm.Sdk.Data.Services.EntityReference';
            isOptionSet = __metadata.type === 'Microsoft.Crm.Sdk.Data.Services.OptionSetValue';
            isMoney = __metadata.type === 'Microsoft.Crm.Sdk.Data.Services.Money';
        }

        if (isLookup) {
            if (restValue.Id)
                uiUtils.setLookUpValueToField(attribute.getName(), restValue.Id, restValue.Name, restValue.LogicalName);
            else attribute.setValue(null);
        }
        else if (isOptionSet || (isMoney && restValue.Value != null)) {
            attribute.setValue(parseFloat(restValue.Value));
        }
        else if (isMoney && restValue.Value == null) {
            attribute.setValue(restValue.Value);
        }
        else {
            if (restValue === undefined)
                restValue = null;
            attribute.setValue(restValue);
        }
    }
};

if (typeof (Neuca.Crm.CustomForms) == "undefined") {
    Neuca.Crm.CustomForms = {};
}

Neuca.Crm.CustomForms = {
    showWindow: function (url, width, height, args, callback) {
        args = args || {};
        args.clientUrl = Xrm.Page.context.getClientUrl();
        args.IS_OUTLOOK_CLIENT = window.IS_OUTLOOK_CLIENT;
        Mscrm.XrmInternal.openDialog(url, { width: width, height: height }, args, null, callback);
    },

    configureCustomWindow: function () {
        try {
            if (window.external && window.external.HostEnabled && window.external.getDialogArguments) {
                window.dialogArguments = window.external.getDialogArguments();
            }
        } catch (e) {
        }
        var args = getDialogArguments();
        window.IS_OUTLOOK_CLIENT = args.IS_OUTLOOK_CLIENT;
    },

    Alert: {
        show: function (message, callback) {
            var callbackInternal = callback || null;
            if (callback) {
                callbackInternal = function (isConfirmed) {
                    window.top.setTimeout(function () {
                        callback(isConfirmed);
                    }, 0);
                };
            }
            if (message) {
                message = (message + '').replace(/\n/g, '<br />');
            }
            var args = { message: message };
            Neuca.Crm.CustomForms.showWindow('$webresource:neu_/HTML/dialogs/neu_alertwindow.htm', 500, 200, args, callbackInternal);
        },
        showError: function (message, detail, callback) {
            var callbackInternal = callback || null;
            if (callback) {
                callbackInternal = function (isConfirmed) {
                    window.top.setTimeout(function () {
                        callback(isConfirmed);
                    }, 0);
                };
            }
            if (message) {
                message = (message + '').replace(/\n/g, '<br />');
            }
            if (detail) {
                detail = (detail + '').replace(/\n/g, '<br />');
            }
            var args = { message: message, detail: detail };
            Neuca.Crm.CustomForms.showWindow('$webresource:neu_/HTML/dialogs/neu_errorwindow.htm', 500, 200, args, callbackInternal);
        },
        showServiceError: function (message, retrieveObject) {
            Neuca.Crm.CustomForms.Alert.showError(message);
        },
        showServiceErrorWithResponseText: function (status, responseText) {
            if (status == 500) {
                var resp = JSON.parse(responseText);
                if (resp.error != null && typeof resp.error !== 'undefined'
                    && resp.error.message != null && typeof resp.error.message !== 'undefined') {
                    Neuca.Crm.CustomForms.Alert.showError(resp.error.message.value, responseText);
                }
            } else {
                Neuca.Crm.CustomForms.Alert.show(responseText);
            }
        }
    },
    Confirm: {
        show: function (message, callback) {
            if (message) {
                message = message.replace(/\n/g, '<br />');
            }
            var args = { message: message };
            var callbackInternal = callback || null;
            if (callback) {
                callbackInternal = function (isConfirmed) {
                    window.top.setTimeout(function () {
                        try {
                            callback(isConfirmed);
                        } catch (ex) {
                            Neuca.Crm.CustomForms.Alert.show(ex);
                        }
                    }, 0);
                };
            }
            Neuca.Crm.CustomForms.showWindow('$webresource:neu_/HTML/dialogs/neu_confirmwindow.htm', 500, 200, args, callbackInternal);
        }
    }
};

