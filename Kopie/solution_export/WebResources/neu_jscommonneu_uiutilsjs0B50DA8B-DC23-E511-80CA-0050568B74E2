    /**
    * @param {String} entityName
    * @param {String} attributes
    * @param {String} order order by field
    * @param {String} filterString e.g 	'<filter type="and"> <condition attribute="new_company" operator="eq" uitype="new_account" value="' + opportunity + '" /></filter>'+
    */
    createFilterXml: function (entityName, attributes, order, filterString) {
        var xml = '<fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="false">' +
            '<entity name="' + entityName + '">';
        if (attributes != null) {
            for (var i = 0; i < attributes.length; i++) {
                xml += '<attribute name="' + attributes[i] + '" />';
            }
        }
        if (order != undefined && order != null) {
            xml += '<order attribute="' + order + '" descending="false" />';
        }
        xml += filterString;
        /*e.g
        '<filter type="and">'+
        '<condition attribute="new_accaunt" operator="eq" uitype="new_company" value="' + opportunity + '" />'+
        '</filter>'+
        */
        xml += '</entity>' + '</fetch>';
        return xml;
    },

    /**
   * @param {String} entityName
   * @param {String} attributes
   * @param {String} order order by field
   * @param {String} filterString e.g 	'<filter type="and"> <condition attribute="new_company" operator="eq" uitype="new_account" value="' + opportunity + '" /></filter>'+
   * @param {int} count number of elements on page, default 20
   * @param {int} page number of page to get, default 1
   * @param {bool} orderDesc is order descending, default false
   * @param {bool} distinct distinct values, default false
   */
    createFilterXmlWithPageOptions: function (entityName, attributes, order, filterString, count, page, orderDesc, distinct) {
        if (this.isNullOrUndefined(page)) {
            page = 1;
        }
        if (this.isNullOrUndefined(count)) {
            count = 20;
        }
        if (distinct == undefined) {
            distinct = false;
        }
        var xml = '<fetch version="1.0" output-format="xml-platform" mapping="logical" distinct="' + distinct + '" page=\'' + page + '\' count=\'' + count + '\'>' +
            '<entity name="' + entityName + '">';
        if (attributes != null) {
            for (var i = 0; i < attributes.length; i++) {
                xml += '<attribute name="' + attributes[i] + '" />';
            }
        }
        if (!this.isNullOrUndefined(order)) {
            if (this.isNullOrUndefined(orderDesc)) {
                orderDesc = false;
            }
            xml += '<order attribute="' + order + '" descending="' + orderDesc + '" />';
        }
        xml += filterString;
        /*e.g
        '<filter type="and">'+
        '<condition attribute="new_accaunt" operator="eq" uitype="new_company" value="' + opportunity + '" />'+
        '</filter>'+
        */
        xml += '</entity>' + '</fetch>';
        return xml;
    },

    /**
    * @param {String} rowId
    * @param {String} rowName
    * @param {Array} cells
    * @param {Array} width if one of values is 'null' default value will ne used
    */
    createGridXml: function (rowId, rowName, cells, width) {
        var gridXml = "<grid name='resultset' " +
            "object='1' " +
            "jump='name' " +
            "select='1' " +
            "icon='1' " +
            "preview='1'>";
        gridXml += "<row name='" + rowName + "' ";
        gridXml += "id='" + rowId + "'>";
        for (var i = 0; i < cells.length; i++) {
            gridXml += "<cell name='" + cells[i] + "'";
            if (width[i] != null)
                gridXml += " width='" + width[i] + "'";
            gridXml += " />";
        }
        gridXml += "</row>" + "</grid>";
        return gridXml;
    },
