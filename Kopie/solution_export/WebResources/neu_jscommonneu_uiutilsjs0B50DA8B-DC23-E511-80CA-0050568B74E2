    bindCssToIframe: function (iframe) {
        var childCtrl = Xrm.Page.ui.controls.get(iframe).getObject().contentWindow.document;
        //copy css links
        var cssLinks = document.getElementsByTagName('link');
        var iframeHead = childCtrl.getElementsByTagName('head')[0];
        for (var i = 0; i < cssLinks.length; i++) {
            var item = cssLinks[i];
            if (item.type === 'text/css') {
                var cssNode = document.createElement('link');
                cssNode.type = 'text/css';
                cssNode.rel = item.rel;
                cssNode.href = item.href;
                iframeHead.appendChild(cssNode);
            }
        }
    },
