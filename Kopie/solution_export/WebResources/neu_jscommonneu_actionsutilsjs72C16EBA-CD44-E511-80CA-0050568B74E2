    getResponseResults: function (xmlResponse) {
        var xrmEntityCollection = function (items) {
            this.value = items;
            this.type = 'EntityCollection';
        };

        var results = XrmServiceToolkit.Soap.SelectSingleNode(xmlResponse, '//a:Results').childNodes;
        var obj = {};

        var getNodeText = function (node) {
            if (typeof (node.text) != "undefined") {
                return node.text;
            } else {
                return node.textContent;
            }
        }

        for (var i = 0; i < results.length; i++) {
            var tempParentNode = results[i];
            // Establish the Key for the Attribute
            var tempParentNodeChildNodes = tempParentNode.childNodes;
            var sKey = XrmServiceToolkit.Soap
                .SelectSingleNodeText(results[i], 'b:key');
            // that.getXmlElements(results[i], 'b:key')[0].childNodes[0].nodeValue;            
            var tempNode = XrmServiceToolkit.Soap.SelectSingleNode(results[i], 'b:value');

            var sTypeItem = tempNode.attributes.getNamedItem('i:type')
            var sType = null;
            if (sTypeItem)
                sType = getNodeText(sTypeItem);

            if (sType === null) {
                obj[sKey] = null;
                continue;
            }

            switch (sType) {
                case "a:OptionSetValue":
                    var entOsv = {};
                    entOsv.type = sType.replace('a:', '');
                    entOsv.value = parseInt(getNodeText(tempNode));
                    obj[sKey] = entOsv;
                    break;

                case "a:EntityReference":
                    entRef = {};
                    entRef.type = sType.replace('a:', '');
                    var oChildNodes = tempNode.childNodes;
                    entRef.id = getNodeText(oChildNodes[0]);
                    entRef.logicalName = getNodeText(oChildNodes[1]);
                    entRef.name = getNodeText(oChildNodes[2]);
                    obj[sKey] = entRef;
                    break;


                case "a:EntityCollection":
                    entRef = new xrmEntityCollection();
                    entRef.type = sType.replace('a:', '');

                    //get all party items....
                    var items = [];
                    var entities = tempNode.childNodes[0];

                    for (var e = 0, lene = entities.childNodes.length; e < lene; e++) {
                        var entity = entities.childNodes[e];
                        var entityId = entity.childNodes[3];
                        var entityLogicalName = entity.childNodes[4];

                        var entityRef = {};
                        entityRef.id = getNodeText(entityId);
                        entityRef.logicalName = getNodeText(entityLogicalName);

                        items[e] = entityRef;
                    }

                    //for (var y = 0, leny = partyNodes[0].childNodes.length; y < leny; y++) {
                    //    var itemNodes = tempParentNode.childNodes[1].childNodes[0].childNodes[y].childNodes[0].childNodes;
                    //    debugger;
                    //    for (var z = 0, lenz = itemNodes.length; z < lenz; z++) {
                    //        var itemNodeChildNodes = itemNodes[z].childNodes;
                    //        var nodeText = getNodeText(itemNodeChildNodes[0]);

                    //        //TODO: tutaj powinno być stworzenie atrybutu


                    //        //if (nodeText === "partyid") {
                    //        var itemRef = {};//new xrmEntityReference();
                    //            itemRef.id = getNodeText(itemNodeChildNodes[1].childNodes[0]);
                    //            itemRef.logicalName = getNodeText(itemNodeChildNodes[1].childNodes[1]);
                    //            itemRef.name = getNodeText(itemNodeChildNodes[1].childNodes[2]);
                    //            items[y] = itemRef;
                    //            //
                    //        //}
                    //    }
                    //}

                    entRef.value = items;
                    obj[sKey] = entRef;
                    break;

                case "a:Money":
                    entCv = {};
                    entCv.type = sType.replace('a:', '');
                    entCv.value = parseFloat(getNodeText(tempNode));
                    obj[sKey] = entCv;
                    break;

                default:
                    entCv = {};
                    entCv.type = sType.replace('c:', '').replace('a:', '');
                    if (entCv.type === "int") {
                        entCv.value = parseInt(getNodeText(tempNode));
                    } else if (entCv.type === "decimal" || entCv.type === "double") {
                        entCv.value = parseFloat(getNodeText(tempNode));
                    } else if (entCv.type === "dateTime") {
                        entCv.value = stringToDate(getNodeText(tempNode));
                    } else if (entCv.type === "boolean") {
                        entCv.value = (getNodeText(tempNode) === 'false') ? false : true;
                    } else {
                        entCv.value = getNodeText(tempNode);
                    }
                    obj[sKey] = entCv;
                    break;
            }
        }

        return obj;
    },

    formatAndThrowEx: function (ex) {
        var text = Neuca.Crm.ActionsUtils.formatEx(ex);
        throw text;
    },

    formatAndAlertEx: function (ex) {
        var text = Neuca.Crm.ActionsUtils.formatEx(ex);
        alert(text);
    },

    formatEx: function (ex) {
        // Wytnij nagłówek z XrmServiceToolkit
        var error = ex.toString();
        var idx = error.indexOf('Message: ', 0);
        if (idx > 0)
            error = error.substr(idx + 9);

        // Wytnij html
        var div = document.createElement("div");
        div.innerHTML = error;
        var text = div.textContent || div.innerText || "";

        return text;
    },

